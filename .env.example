# .env.example — copy these into Vercel → Settings → Environment Variables
# (Do NOT commit a real .env file.)

# --- Google OAuth2 (folder owner's account → real storage quota) ---
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REFRESH_TOKEN=1//your-long-lived-refresh-token

# --- Target Google Drive folder (from your shared link) ---
GDRIVE_FOLDER_ID=1V2H5XcRbsbtABBIyEQF_9YUCol6YK03I

# --- Optional: lock CORS to your frontend origin (default "*") ---
ALLOWED_ORIGIN=*
